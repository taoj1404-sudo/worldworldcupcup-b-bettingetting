# ==============================================
# WorldCup Betting Platform - 生产环境配置
# ==============================================
# 复制此文件为 .env 并修改所有 CHANGE_ME 值

# ============ 数据库 ============
# PostgreSQL 连接字符串（容器内用服务名，外部用 localhost）
DATABASE_URL=postgresql://worldcup:你的数据库密码@db:5432/worldcup_betting

# ============ JWT 认证 ============
# 至少 32 位随机字符，可用: openssl rand -base64 32
JWT_SECRET=替换为随机密钥（至少32字符）
JWT_REFRESH_SECRET=替换为另一个随机密钥（至少32字符）
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============ 应用配置 ============
NODE_ENV=production
# 替换为你的服务器公网 IP 或域名
NEXTAUTH_URL=http://你的服务器IP:3000
NEXTAUTH_SECRET=替换为随机密钥

# ============ Redis ============
REDIS_URL=redis://redis:6379

# ============ 数据同步 API（可选）============
# API-Football（实时比分）
# https://www.api-football.com/
API_FOOTBALL_KEY=你的API密钥
API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com

# The Odds API（赔率数据）
# https://the-odds-api.com/
THE_ODDS_API_KEY=你的API密钥

# ============ 同步设置 ============
# 实时比赛同步间隔（秒）
SYNC_INTERVAL_LIVE=60
# 赛前比赛同步间隔（秒）
SYNC_INTERVAL_SCHEDULED=300
