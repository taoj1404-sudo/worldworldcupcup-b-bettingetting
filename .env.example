# ─── 数据库 ──────────────────────────────────────────
# 开发环境：本地 PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/worldcup_betting"

# 生产环境：使用你的数据库连接字符串
# DATABASE_URL="postgresql://user:password@host:5432/worldcup_betting"

# ─── Next.js ─────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-secure-secret"

# ─── JWT ─────────────────────────────────────────────
# 生产环境：使用强随机密钥（至少 32 字符）
JWT_SECRET="dev-jwt-secret-key-at-least-32-chars!!"
JWT_REFRESH_SECRET="dev-refresh-secret-key-at-least-32chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Redis（可选）─────────────────────────────────────
# 开发环境：本地 Redis
REDIS_URL="redis://localhost:6379"

# 生产环境：使用你的 Redis 连接字符串
# REDIS_URL="redis://user:password@host:6379"

# ─── 环境 ─────────────────────────────────────────────
NODE_ENV="development"
