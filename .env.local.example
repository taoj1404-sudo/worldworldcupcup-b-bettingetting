# ─── 数据库 ──────────────────────────────────────────
# 本地开发：postgresql://用户名:密码@localhost:5432/数据库名
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/worldcup_betting"

# ─── Next.js ─────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-key-at-least-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-at-least-32-chars"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── 支付宝（沙箱） ───────────────────────────────────
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_SANDBOX=true

# ─── 微信支付 ─────────────────────────────────────────
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""

# ─── Redis ────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── 环境 ─────────────────────────────────────────────
NODE_ENV="development"
